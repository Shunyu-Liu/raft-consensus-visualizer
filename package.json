{
  "name": "raft-consensus-visualizer",
  "private": true,
  "version": "1.1.0",
  "description": "Interactive educational visualization of the Raft consensus algorithm.",
  "license": "MIT",
  "author": "Shunyu Liu",
  "type": "module",
  "keywords": [
    "raft",
    "consensus",
    "distributed-systems",
    "visualization",
    "simulator",
    "education",
    "react",
    "typescript",
    "vite",
    "leader-election",
    "log-replication",
    "network-partition"
  ],
  "engines": {
    "node": ">=24.14.0 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b --pretty false",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "check:full": "npm run check && npm run test:coverage && npm run test:e2e"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.16.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
